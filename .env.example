# ══════════════════════════════════════════════════════════════════
# Monica's Miracle Mop — environment variables
#
# ✅ REQUIRED IN VERCEL (Production + Preview) — the site won't work
#    properly without these:
#      NEXT_PUBLIC_SITE_URL, DATABASE_URL, RESEND_API_KEY, EMAIL_FROM,
#      OWNER_EMAIL, BCC_EMAIL, CALENDAR_FEED_TOKEN, ADMIN_PASSWORD
#
# ⏸  NOT NEEDED YET (online deposits are disabled):
#      STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
#      NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
# ══════════════════════════════════════════════════════════════════

# ── Required in Vercel ──────────────────────────────────────────────

# Public site URL, no trailing slash (e.g. https://monicasmiraclemop.co.uk)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon Postgres — booking storage (from console.neon.tech → Connection string)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Resend — booking emails.
# ⚠ Until a domain is verified at resend.com/domains, Resend only delivers
#   to the account owner's inbox (monicasmiraclemop@gmail.com). Use
#   "... <onboarding@resend.dev>" as EMAIL_FROM while testing, then switch
#   to the verified domain to reach clients + BCC.
RESEND_API_KEY=re_...
EMAIL_FROM="Monica's Miracle Mop <bookings@monicasmiraclemop.co.uk>"
OWNER_EMAIL=monicasmiraclemop@gmail.com
# BCC'd on every booking email (optional but recommended)
BCC_EMAIL=aaron@validatethis.co.uk

# Password for Kasey's admin dashboard at /admin (pick something strong)
ADMIN_PASSWORD=pick-a-strong-password

# Secret for the owner's calendar subscription feed:
#   webcal://<site>/api/calendar?key=<this value>
# Any long random string (32+ chars).
CALENDAR_FEED_TOKEN=generate-a-long-random-string

# ── Optional: Google Calendar sync (bookings appear in Kasey's
#    calendar instantly). Silent no-op until all three are set.
#    Setup: Google Cloud project → enable Calendar API → create service
#    account + JSON key → Kasey shares her calendar with the service
#    account email ("Make changes to events"). Add these to Vercel too.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=mmm-bookings@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_CALENDAR_ID=monicasmiraclemop@gmail.com

# ── Not needed while online deposits are off ────────────────────────

# Stripe (deposits disabled — DEPOSIT_PERCENT=0 in lib/data/services.ts)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
